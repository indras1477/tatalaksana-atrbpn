# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Both web and api node_modules
web/node_modules/
api/node_modules/

# testing
/coverage

# next.js - generated files that should be rebuilt on pull
.next/
web/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files - keep root .env files for defaults, ignore local overrides
.env.local
.env.development
.env.production
web/.env.local
api/.env.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
